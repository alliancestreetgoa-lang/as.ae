# Copy this file to .env.local for local development, or set these as build-time
# environment variables in your deployment pipeline (e.g. GitHub Actions).
# Both variables below are required for `npm run dev` too — there is no NODE_ENV-based fallback.

# The active site's canonical base URL. Must be a valid absolute URL, no trailing slash.
# Staging: https://shaukinsv.com
# Production (future): https://alliancestreet.ae
NEXT_PUBLIC_SITE_URL=https://shaukinsv.com

# Must be exactly "staging" or "production" — distinguishes the deployment target.
# Do NOT infer this from NODE_ENV; set it explicitly.
NEXT_PUBLIC_SITE_ENVIRONMENT=staging

# Endpoint of the deployed chatbot Cloudflare Worker (existing var, already used
# by src/lib/chat-config.ts — included here for completeness).
NEXT_PUBLIC_CHAT_ENDPOINT=https://alliance-chat.alliancestreetgoa.workers.dev

# Optional GA4 measurement ID (src/lib/analytics-config.ts). Leaving this unset
# disables analytics entirely — no gtag.js script loads and trackEvent() no-ops.
# Must look like a real GA4 ID (starts with "G-") or it's ignored the same as
# if it were unset. Replace the placeholder below with the real ID when ready;
# do not commit a real measurement ID to this example file.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
